#!/bin/bash

# Initialize module
echo "📦 Initializing Go module..."
go mod init flutter-tool 2>/dev/null || echo "  (already initialized)"
echo ""

# Build ARM64
echo "🔨 Building ARM64 binary..."
GOOS=linux GOARCH=arm64 CGO_ENABLED=0 go build -ldflags="-s -w" -o flutter-tool-arm64 main.go

if [ -f "flutter-tool-arm64" ]; then
    echo ""
    echo "✅ SUCCESS!"
    echo ""
    
    # Show comparison
    echo "📊 Size comparison:"
    echo "  Original: $(ls -lh flutter-tool | awk '{print $5}')"
    echo "  Binary:   $(ls -lh flutter-tool-arm64 | awk '{print $5}')"
    echo ""
    echo "🧪 Test it:"
    echo "  ./flutter-tool-arm64 help"
    echo "  ./flutter-tool-arm64 --version"
    echo ""
    echo "📦 Install it:"
    echo "  sudo cp flutter-tool-arm64 /usr/local/bin/flutter-tool"
    echo ""
else
    echo "❌ Build failed!"
    exit 1
fi
