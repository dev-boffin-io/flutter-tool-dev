#!/bin/bash

# Configuration
BINARY_NAME="flutter-tool"
SOURCE_FILE="main.go"
OUTPUT_DIR="./bin"

# Colors
BLUE="\e[34m"; GREEN="\e[32m"; RED="\e[31m"; NC="\e[0m"; BOLD="\e[1m"

echo -e "${BLUE}${BOLD}📦 Initializing Go module...${NC}"
# Initialize module if go.mod doesn't exist
if [ ! -f "go.mod" ]; then
    go mod init flutter-tool &>/dev/null
    go mod tidy &>/dev/null
    echo "  (Module initialized)"
else
    echo "  (Already initialized)"
fi

# Create bin directory if it doesn't exist
if [ ! -d "$OUTPUT_DIR" ]; then
    mkdir -p "$OUTPUT_DIR"
fi

echo -e "\n${BLUE}${BOLD}🔨 Building ARM64 binary to ${OUTPUT_DIR}/${BINARY_NAME}...${NC}"

# Build process with optimization flags
GOOS=linux GOARCH=arm64 CGO_ENABLED=0 go build -ldflags="-s -w" -o "${OUTPUT_DIR}/${BINARY_NAME}" "$SOURCE_FILE"

if [ -f "${OUTPUT_DIR}/${BINARY_NAME}" ]; then
    echo -e "\n${GREEN}${BOLD}✅ SUCCESS!${NC}"
    echo -e "----------------------------------------"
    
    # Show comparison logic
    # Note: 'flutter-tool' (shell) vs binary comparison
    echo -e "📊 ${BOLD}Size Summary:${NC}"
    if [ -f "flutter-tool" ]; then
        ORIG_SIZE=$(ls -lh flutter-tool | awk '{print $5}')
        echo -e "  Shell Script: $ORIG_SIZE"
    fi
    BIN_SIZE=$(ls -lh "${OUTPUT_DIR}/${BINARY_NAME}" | awk '{print $5}')
    echo -e "  Binary:       $BIN_SIZE"
    
    echo -e "----------------------------------------"
    echo -e "🧪 ${BOLD}Test it:${NC}"
    echo -e "  ${OUTPUT_DIR}/${BINARY_NAME} help"
    echo -e "  ${OUTPUT_DIR}/${BINARY_NAME} --version"
    
    echo -e "\n📦 ${BOLD}Install globally:${NC}"
    echo -e "  sudo cp ${OUTPUT_DIR}/${BINARY_NAME} /usr/local/bin/"
    echo "----------------------------------------"
else
    echo -e "\n${RED}${BOLD}❌ Build failed!${NC}"
    exit 1
fi
